{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/movie/(.*)", "dest": "/api/index.js" },
    { "src": "/tv/(.*)", "dest": "/api/index.js" },
    { "src": "/blog/(.*)", "dest": "/api/index.js" },
    { "src": "/.well-known/assetlinks.json", "dest": "/public/assetlinks.json" },
    { "src": "/downloads/(.*)", "dest": "/public/downloads/$1" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/privacy-policy", "dest": "/public/privacy-policy.html" },
    { "src": "/terms-of-service", "dest": "/public/terms-of-service.html" },
    { "src": "/api(.*)", "dest": "/api/index.js" },
    { "src": "/((?!api/|downloads/|\\.well-known/|public/).*)", "dest": "/public/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "crons": [
    {
      "path": "/api/bot?cron=true",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/downloads/movienest.apk",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"movienest.apk\""
        },
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ]
}
