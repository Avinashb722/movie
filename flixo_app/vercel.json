{
  "version": 2,
  "builds": [
    { "src": "build/web/**", "use": "@vercel/static" },
    { "src": "vercel_proxy/api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/.well-known/assetlinks.json", "dest": "/assetlinks.json" },
    { "src": "/downloads/(.*)", "dest": "/downloads/$1" },
    { "src": "/api(.*)", "dest": "vercel_proxy/api/index.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
